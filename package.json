{
  "name": "runql-duckdb",
  "displayName": "RunQL DuckDB Connector",
  "description": "Optional DuckDB connector for RunQL.",
  "publisher": "runql",
  "icon": "media/icon.png",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DVCodeLabs/RunQL-DuckDB.git"
  },
  "bugs": {
    "url": "https://github.com/DVCodeLabs/RunQL-DuckDB/issues"
  },
  "homepage": "https://runql.com/opensource/",
  "keywords": [
